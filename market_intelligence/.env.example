# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Market Intelligence Platform
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=market_intelligence
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=prefer

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0

# ── External API Keys ─────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=market-intelligence-bot/1.0

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
